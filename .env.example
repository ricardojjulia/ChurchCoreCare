# Online Supabase session pooler only. Local database hosts are rejected.
DB_HOST=aws-1-us-east-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=replace-with-supabase-database-password
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=1

# Generate independent secrets before startup. Example secret values are intentionally blank.
DB_ENCRYPTION_KEY=
DB_ENCRYPTION_HMAC_KEY=
SESSION_SECRET=

DEMO_ENVIRONMENT=true
VITE_DEMO_ENVIRONMENT=true
SEED_DEV_PORTAL_DATA=false
ENABLE_TENANT_HOST_ROUTING=false
TENANT_STRICT_HOST_ROUTING=false
TENANT_ALLOWED_SLUGS=system
TENANT_SLUG_CACHE_TTL_MS=60000
TENANT_DB_MAP=
PUBLIC_PORTAL_TENANT_ID=system
