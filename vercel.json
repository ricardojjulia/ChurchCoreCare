{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm deploy:build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "apps/web/public",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
