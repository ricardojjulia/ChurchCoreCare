#!/usr/bin/env bash
set -euo pipefail

current_branch="$(git rev-parse --abbrev-ref HEAD)"
if [[ "$current_branch" == "main" || "$current_branch" == "master" ]]; then
  echo "Direct push to $current_branch is blocked locally."
  echo "Create a feature branch and open a PR instead:"
  echo "  git switch -c feature/your-change"
  echo "  git push -u origin feature/your-change"
  exit 1
fi
