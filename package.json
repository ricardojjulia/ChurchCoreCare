{
  "name": "churchcore-care",
  "version": "7.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node --env-file=.env ops/start-all.mjs",
    "start:all": "node --env-file=.env ops/start-all.mjs",
    "start:web": "pnpm --filter @churchcore/web start",
    "start:api": "pnpm --filter @churchcore/api start",
    "start:api:standalone": "pnpm --filter @churchcore/api start:standalone",
    "start:worker": "pnpm --filter @churchcore/worker start",
    "reset:language": "node ops/reset-language-settings.mjs && node ops/push-clean-messages.mjs",
    "i18n:status": "node --env-file=.env ops/i18n-status.mjs",
    "i18n:translate": "node --env-file=.env ops/translate-locale.mjs",
    "localization:test": "pnpm --filter '@localization-governance/*' test && node --test ops/localization-governance/test/*.test.mjs",
    "localization:test:postgres": "node ops/localization-governance/test-postgres.mjs",
    "localization:migrate": "node ops/localization-governance/migrate-churchcore.mjs",
    "localization:build:es-pr": "node ops/localization-governance/build-es-pr.mjs",
    "localization:publish:es-pr": "node --env-file=.env ops/localization-governance/build-es-pr.mjs --postgres --tenant system --write",
    "localization:verify-pack": "node ops/localization-governance/verify-packed-consumer.mjs",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:step12": "node ops/step12-validate.mjs",
    "policy:tenant": "node ops/check-tenant-policy.mjs",
    "test:security": "node ops/security-regression.mjs",
    "security:appsec": "node ops/appsec-scan.mjs",
    "security:db": "node ops/db-security-scan.mjs",
    "security:nightly": "node ops/nightly-security-runner.mjs",
    "security:nightly:dry": "node ops/nightly-security-runner.mjs --dry-run",
    "test:e2e": "playwright test tests/e2e/high-value-journeys.spec.mjs",
    "test:e2e:demo-feedback": "playwright test tests/e2e/demo-feedback.spec.mjs",
    "test:load": "bash tests/load/run.sh",
    "test:load:full": "bash tests/load/run.sh full",
    "test:load:auth": "bash tests/load/run.sh auth",
    "test:load:intake": "bash tests/load/run.sh intake",
    "test:load:notes": "bash tests/load/run.sh notes",
    "test:launch-readiness": "playwright test tests/e2e/launch-readiness.spec.mjs",
    "demo:apply": "node --env-file=.env ops/demo-dataset/apply.mjs",
    "demo:verify": "node --env-file=.env ops/demo-dataset/verify.mjs",
    "demo:finalize": "node --env-file=.env ops/demo-dataset/finalize.mjs",
    "demo:sql:generate": "node --env-file=.env ops/demo-dataset/generate-sql.mjs",
    "demo:sql:apply": "node --env-file=.env ops/demo-dataset/apply-sql.mjs",
    "demo:sql:refresh": "pnpm demo:sql:generate && pnpm demo:sql:apply",
    "deploy:build": "pnpm --filter @churchcore/web build",
    "deploy:supabase": "node --env-file=.env ops/deployment/apply-supabase.mjs",
    "deploy:verify": "node --env-file=.env ops/deployment/verify-supabase.mjs",
    "test:smoke": "node ops/smoke-auth.mjs",
    "agent:translation:build": "docker compose --profile agent build translation-guardian",
    "agent:translation:run": "docker compose --profile agent up translation-guardian",
    "agent:translation:run:detached": "docker compose --profile agent up -d translation-guardian",
    "agent:translation:logs": "docker compose --profile agent logs -f translation-guardian",
    "agent:translation:down": "docker compose --profile agent stop translation-guardian"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "axe-core": "^4.11.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["argon2"],
    "overrides": {
      "tar": ">=7.5.11",
      "protobufjs": ">=7.5.5",
      "brace-expansion": ">=1.1.13"
    }
  }
}
